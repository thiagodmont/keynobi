{
  "name": "android-ide",
  "version": "0.1.0",
  "description": "AI-First Android Development Environment",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "generate:bindings": "cd src-tauri && cargo test && echo 'TypeScript bindings regenerated in src/bindings/'",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "perf:collect": "node scripts/collect-metrics.mjs",
    "perf:report": "node scripts/collect-metrics.mjs --report",
    "build:dmg": "tauri build --target aarch64-apple-darwin --bundles dmg",
    "build:dmg:intel": "tauri build --target x86_64-apple-darwin --bundles dmg",
    "build:dmg:universal": "tauri build --target universal-apple-darwin --bundles dmg"
  },
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9.0.0",
    "eslint-plugin-solid": "^0.14.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.1"
  }
}
