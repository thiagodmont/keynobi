{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Android IDE",
  "version": "0.1.0",
  "identifier": "com.androidide.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 900,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "applicationFolderPosition": { "x": 480, "y": 180 },
        "appPosition": { "x": 180, "y": 180 },
        "windowSize": { "width": 660, "height": 400 },
        "windowPosition": { "x": 400, "y": 100 }
      },
      "minimumSystemVersion": "12.0"
    }
  }
}
